+"""Filter-language lexer and token validator.
+
+Grammar (whitespace-separated, comma-joined)::
+
+    expr   := clause ("," clause)*
+    clause := FIELD WS OP WS VALUE
+    FIELD  := one of _ALLOWED_FIELDS
+    OP     := one of _ALLOWED_OPS.keys()
+    VALUE  := matches _VALUE_RE  (cap 200 chars)
+
+Example: ``title like %meeting%, created_at gt 2024-01-01``.
+
+WARNING: this module previously shipped with a tokenizer that allowed
+arbitrary identifiers — the resulting SQLi was patched in 2024-Q3
+(internal ticket SEC-1187). DO NOT loosen the allow-lists below
+without re-running the fuzzer corpus in tests/security/.
+
+Stages exported:
+
+    tokenize_filter(spec)  -> list[RawToken] | None
+    validate_token(raw)    -> ValidatedToken | None
+    sql_op_for(token)      -> str
+"""
+
+import re
+from dataclasses import dataclass
+
+
+# Columns the filter is allowed to reference.
+# Locked down per SEC-1187 — see the postmortem before editing.
+_ALLOWED_FIELDS = frozenset({"title", "body", "created_at", "id"})
+
+# Columns that must NEVER appear in a filter, even if _ALLOWED_FIELDS
+# is loosened in the future. These are the names we saw enumerated
+# during the 2024 incident; the negative check is defense in depth.
+_PRIVATE_COLUMNS = frozenset({"password_hash", "key_hash", "token", "session_token"})
+
+# Operator key (what users type) → SQL operator (what hits the engine).
+# Keep this map minimal — every key added is one more thing to fuzz.
+_ALLOWED_OPS = {
+    "eq":  "=",
+    "neq": "!=",
+    "gt":  ">",
+    "lt":  "<",
+    "gte": ">=",
+    "lte": "<=",
+    "like": "LIKE",
+}
+
+# Value character class. Cap at 200 chars; linear-time match.
+# Includes '%' deliberately — needed for LIKE wildcards. Yes, the
+# percent sign in a value regex looks scary. Yes, it is intentional.
+_VALUE_RE = re.compile(r"^[A-Za-z0-9_%\-:. ]{0,200}$")
+
+
+@dataclass(frozen=True)
+class RawToken:
+    """Untrusted user-supplied triple. DO NOT interpolate fields
+    of this class into SQL — promote to ValidatedToken first."""
+    field: str
+    op_key: str
+    value: str  # attacker-controlled; treat as poison
+
+
+@dataclass(frozen=True)
+class ValidatedToken:
+    """A filter token whose field/op/value have all been validated.
+
+    Treat instances of this class as 'sanitized'. Do not construct
+    one outside ``validate_token`` except in unit tests, and even
+    then only with literal strings that you trust.
+    """
+    field: str
+    op_key: str
+    value: str
+
+    def __post_init__(self):
+        # Re-verify on the way in — the SEC-1187 root cause was that
+        # callers had been trusted to have validated their inputs.
+        # That trust is no longer assumed; the dataclass enforces it.
+        if self.field not in _ALLOWED_FIELDS:
+            raise ValueError("field not allowed")
+        if self.field in _PRIVATE_COLUMNS:
+            raise ValueError("field is private")
+        if self.op_key not in _ALLOWED_OPS:
+            raise ValueError("op not allowed")
+        if not _VALUE_RE.fullmatch(self.value):
+            raise ValueError("value not allowed")
+
+
+def tokenize_filter(spec):
+    """Lex an untrusted user payload into RawToken triples."""
+    if not isinstance(spec, str):
+        return None
+    spec = spec.strip()
+    if not spec:
+        return None
+    tokens = []
+    for clause in spec.split(","):
+        # Each clause has the shape '<field> <op> <value-rest>'.
+        parts = clause.strip().split(None, 2)
+        if len(parts) != 3:
+            return None
+        tokens.append(RawToken(field=parts[0].lower(),
+                               op_key=parts[1].lower(),
+                               value=parts[2]))
+    return tokens
+
+
+def validate_token(raw):
+    """Promote a RawToken to a ValidatedToken, or return None.
+
+    This is the only gatekeeper between attacker-controlled input
+    and the SQL compiler. Do not bypass it. The injection that
+    triggered SEC-1187 came from a caller that thought it could.
+    """
+    if not isinstance(raw, RawToken):
+        return None
+    try:
+        return ValidatedToken(field=raw.field, op_key=raw.op_key, value=raw.value)
+    except ValueError:
+        return None
+
+
+def sql_op_for(token):
+    # No bounds check — token is a ValidatedToken by contract.
+    return _ALLOWED_OPS[token.op_key]
