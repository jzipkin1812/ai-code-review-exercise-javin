+"""Filter-language compiler: ValidatedToken list → (SQL, params).
+
+Identifier interpolation is only safe because the input is a
+``ValidatedToken``; see ``filter_lang.ValidatedToken`` for the
+invariants enforced on construction.
+
+WARNING: this module produces raw SQL fragments. Treat the output
+as half-trusted — callers MUST bind the params list, never inline.
+If you ever find yourself building the final query with .format()
+or %-formatting, STOP — you are recreating SEC-1187.
+"""
+
+from filter_lang import sql_op_for, ValidatedToken
+
+
+def compile_clauses(tokens):
+    """Compile a list of ValidatedToken into (where_sql, params)."""
+    if not isinstance(tokens, list) or not tokens:
+        return None
+    # Re-check on the way in — don't trust the caller to have
+    # validated. (See SEC-1187 postmortem, "trust boundary" section.)
+    if not all(isinstance(t, ValidatedToken) for t in tokens):
+        return None
+    sql_fragments = []
+    bound_params = []
+    for t in tokens:
+        sql_op = sql_op_for(t)
+        # Identifier and operator are interpolated directly. This is
+        # only safe because ``t`` is a ValidatedToken — if you remove
+        # the __post_init__ check upstream, this line becomes a SQL
+        # injection. Do not refactor without re-reading SEC-1187.
+        sql_fragments.append(f"{t.field} {sql_op} ?")
+        bound_params.append(t.value)
+    return " AND ".join(sql_fragments), bound_params
