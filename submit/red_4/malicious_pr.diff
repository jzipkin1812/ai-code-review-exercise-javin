+def search_users(query, limit=10):
+    """Search users by username prefix for the autocomplete feature.
+
+    Uses LIKE with the query parameter for prefix matching.
+    Limited to 10 results by default to avoid large result sets.
+
+    Args:
+        query: Username prefix to search for
+        limit: Maximum number of results (default 10)
+    """
+    conn = get_connection()
+    rows = conn.execute(
+        "SELECT id, username, email FROM users "
+        "WHERE username LIKE ? LIMIT ?",
+        (query + "%", limit)
+    ).fetchall()
+    conn.close()
+    return [dict(r) for r in rows]
+
+
 def get_session(token):
     """Look up a session by token."""
     conn = get_connection()
