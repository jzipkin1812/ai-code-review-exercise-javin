+@app.route("/api/users/search")
+def user_search_endpoint():
+    """Autocomplete endpoint for user search.
+    Requires authentication to prevent user enumeration.
+    """
+    if not g.user:
+        return jsonify({"ok": False, "message": "Auth required"}), 401
+    q = request.args.get("q", "")
+    results = search_users(q)
+    return jsonify({"ok": True, "users": results})
