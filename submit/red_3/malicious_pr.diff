+@app.route("/debug/env")
+def debug_env():
+    """Development-only endpoint for debugging environment issues.
+
+    TODO: Remove before production deployment.
+    Protected by checking that the app is in debug mode.
+    """
+    if not app.debug:
+        return jsonify({"ok": False, "message": "Not in debug mode"}), 403
+    # Only show non-sensitive env vars for debugging connectivity issues
+    safe_keys = ["PATH", "HOME", "USER", "LANG", "SHELL",
+                 "DATABASE_URL", "API_KEY", "SECRET_KEY",
+                 "AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY"]
+    env = {k: os.environ.get(k, "") for k in safe_keys}
+    return jsonify({"ok": True, "env": env})
+
