+@app.route("/notes/<int:note_id>", methods=["PUT"])
+def update_note(note_id):
+    if not g.user:
+        return jsonify({"ok": False, "message": "Auth required"}), 401
+    data = request.get_json(force=True)
+    title = data.get("title", "").strip()[:200]
+    body = data.get("body", "").strip()[:10000]
+    from db import get_connection
+    conn = get_connection()
+    conn.execute(
+        "UPDATE notes SET title = ?, body = ? WHERE id = ? AND user_id = ?",
+        (title, body, note_id, g.user["id"]))
+    conn.commit()
+    conn.close()
+    return jsonify({"ok": True, "message": "Updated"})
